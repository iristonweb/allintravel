# Server port (default: 5000)
PORT=5000

# Public app URL (required in production for OAuth + cookies)
APP_URL=https://www.allintravel.online

# Optional: API base URL for the client (e.g. http://localhost:5000 when frontend is on another origin). Leave unset when frontend and API are served together.
# VITE_API_ORIGIN=

# Giphy — поиск GIF в чате (https://developers.giphy.com/)
# VITE_GIPHY_API_KEY=

# Mapbox GL (optional fallback if Yandex key is not set)
# VITE_MAPBOX_TOKEN=pk.your_mapbox_token

# Yandex Maps JavaScript API (карта /map, планировщик) — приоритет над Mapbox/Leaflet
# VITE_YANDEX_MAPS_API_KEY=your_yandex_maps_js_api_key

# Yandex Maps API (https://developer.tech.yandex.ru/) — не коммитьте ключи в git
# Geosuggest улучшает подсказки адресов и заведений в РФ (бесплатный лимит в кабинете)
# JavaScript API карт — /map (отдельный ключ в кабинете, не путать с ниже)
# VITE_YANDEX_MAPS_API_KEY=your_yandex_maps_js_api_key

# Геосаджест — подсказки при вводе (suggest-maps.yandex.ru)
# YANDEX_GEOSUGGEST_API_KEY=your_yandex_geosuggest_api_key

# HTTP Геокодер — координаты и уточнение адреса (geocode-maps.yandex.ru)
# YANDEX_GEOCODER_API_KEY=your_yandex_geocoder_api_key

# Маршрутизация — детали маршрута между точками (api.routing.yandex.net)
# YANDEX_ROUTER_API_KEY=your_yandex_router_api_key

# Session secret for cookies (required in production: random string, 32+ chars)
SESSION_SECRET=your-secret-key-change-in-production

# Comma-separated admin emails (lowercase)
# ADMIN_EMAILS=admin@example.com

# Postgres connection string (required for email/password accounts in production) (enables persistent storage + geo autocomplete)
# Example (Neon):
# DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Example (local):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/all_in_travel
#DATABASE_URL=

# Google OAuth (optional — enables "Sign in with Google")
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Jamendo — поиск CC-музыки для «Моя музыка» (https://developer.jamendo.com/)
# JAMENDO_CLIENT_ID=

# Vercel Blob — постоянное хранение фото/видео/аудио, аватаров и музыки (обязательно на Vercel prod)
# 1. Vercel Dashboard → Storage → Blob → Projects → Connect to Project (один store на проект)
# 2. Новые store: OIDC — BLOB_STORE_ID (+ VERCEL_OIDC_TOKEN на деплое автоматически)
#    Старый режим: BLOB_READ_WRITE_TOKEN (vercel env pull — локально)
# BLOB_ACCESS=auto — public store → прямые https URL (рекомендуется для фото в чате/рассылке); private → /api/media/blob
# BLOB_WEBHOOK_PUBLIC_KEY — только webhook, для загрузок НЕ подходит


# Web Push VAPID keys (required on Vercel for real push — generate with: npx web-push generate-vapid-keys)
# Set in Vercel → Project → Settings → Environment Variables (Production + Preview)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@allintravel.online

# Playwright E2E (optional — authenticated flows skip without these)
# E2E_EMAIL=
# E2E_PASSWORD=

# OpenAI — AI Trip Copilot (optional; без ключа работает эвристика)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ЮKassa — оплата платных событий (без ключей — mock checkout)
# YUKASSA_SHOP_ID=
# YUKASSA_SECRET_KEY=

# Affiliate marker для Ostrovok / Booking.com
# AFFILIATE_MARKER=allintravel

# Stripe Connect — marketplace route sales (optional; mock without key)
# STRIPE_SECRET_KEY=

# Upstash Redis — cross-instance realtime pub/sub (optional)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Dedicated WebSocket worker (npm run ws:dev)
# WS_PORT=8081
