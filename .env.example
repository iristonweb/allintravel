# Server port (default: 5000)
PORT=5000

# Public app URL (required in production for OAuth + cookies)
APP_URL=https://allintravel.vercel.app

# Optional: API base URL for the client (e.g. http://localhost:5000 when frontend is on another origin). Leave unset when frontend and API are served together.
# VITE_API_ORIGIN=

# Mapbox GL (optional fallback if Yandex key is not set)
# VITE_MAPBOX_TOKEN=pk.your_mapbox_token

# Yandex Maps JavaScript API (карта /map, планировщик) — приоритет над Mapbox/Leaflet
# VITE_YANDEX_MAPS_API_KEY=your_yandex_maps_js_api_key

# Yandex Geocoder + Suggest (сервер: автодополнение городов, только на backend)
# YANDEX_GEOCODER_API_KEY=your_yandex_geocoder_api_key

# Session secret for cookies (use a strong random value in production)
SESSION_SECRET=your-secret-key-change-in-production

# Postgres connection string (required for email/password accounts in production) (enables persistent storage + geo autocomplete)
# Example (Neon):
# DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Example (local):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/all_in_travel
#DATABASE_URL=

# Google OAuth (optional — enables "Sign in with Google")
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Web Push VAPID keys (optional — generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@allintravel.app
